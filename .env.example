# ============================================================
# 配置优先级：数据库覆盖 > 本文件 > 代码默认值
# ============================================================
# 本文件中的值是「兜底默认」：管理后台「系统设置」页保存的覆盖值
# 存储于 MySQL system_settings 表，运行时优先级最高。
# 首次部署必须在此填写密钥与连接串（数据库自举依赖它们）；
# 日常调参（模型名、阈值、开关等）建议直接在管理后台修改。
# 注意：连接串 / 端口 / 日志级别等启动期读取的配置，在后台修改后需重启服务生效。

# =======================
# 大语言模型（LLM）
# =======================
# 可选：dashscope（云端）| local（本地部署，权威路径，不回退云端）
LLM_PROVIDER=dashscope
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.7-plus
# 本地 LLM 配置（=local 时生效；=dashscope 时作为失败降级）
# LOCAL_LLM_URL=http://localhost:11434/v1
# LOCAL_LLM_MODEL=qwen3:7b

# =======================
# 向量模型（Embedding）：切换 provider/模型/维度后必须重建索引
# =======================
EMBEDDING_PROVIDER=dashscope
EMBEDDING_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1536
# 本地 Embedding 配置（维度随模型变化，如 bge-m3 为 1024，需同步修改 EMBEDDING_DIM）
# LOCAL_EMBEDDING_URL=http://localhost:11434/v1
# LOCAL_EMBEDDING_MODEL=BAAI/bge-m3

# 向量索引算法对照：主索引 IVF_FLAT，shadow 索引 HNSW（修改后需重建索引生效）
VECTOR_INDEX_TYPE=IVF_FLAT
SHADOW_INDEX_TYPE=HNSW
# Shadow 检索切流比例（0-100），按百分比把检索请求切流到 shadow 索引进行只检索不生成的对照实验
SHADOW_RATIO=0

# =======================
# Reranker 模型
# =======================
RERANKER_PROVIDER=dashscope
RERANKER_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
RERANKER_MODEL=qwen3-rerank
# 本地 Reranker 配置（仅当 RERANKER_PROVIDER=local 时生效）
# 使用前请先启动本地服务：docker compose --profile reranker up -d
# 服务暴露 Cohere-compatible /rerank 端点，路径不要带 /v1
LOCAL_RERANKER_URL=http://127.0.0.1:8008
LOCAL_RERANKER_MODEL=BAAI/bge-reranker-large

# =======================
# 存储配置（后台修改后需重启生效）
# =======================
MILVUS_URI=http://localhost:19531
MILVUS_COLLECTION=cloudbrief_chunks

REDIS_URL=redis://localhost:6381/0

# 自举读取：启动时先按此连接串读出 DB 中的 mysql_url 覆盖值，再以覆盖值建连接池
MYSQL_URL=mysql+pymysql://cloudbrief:cloudbrief@localhost:3307/cloudbrief

BM25_INDEX_PATH=./data/bm25_index.pkl

# Neo4j 图数据库（GraphRAG 可选依赖）
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cloudbrief

# 知识库上传文件存储目录与单文件大小上限（字节）
# KB_STORAGE_PATH=./data/kb
# KB_MAX_FILE_SIZE=52428800

# =======================
# 业务配置（均可在管理后台覆盖，即时生效）
# =======================
LOG_LEVEL=INFO

# 拒答阈值：reranker 最高分低于该值时直接拒答（评测阶段根据 Eval Set 调优）
REFUSAL_THRESHOLD=0.3

# 时效阈值（天）：来源更新时间与当前时间差超过该值时提示过期
STALE_THRESHOLD_DAYS=90

# 多轮历史保留轮数
MAX_HISTORY_ROUNDS=10

# 模型调用超时（秒）
REQUEST_TIMEOUT=30

# 文件上传成功后是否自动触发单文件索引
AUTO_INDEX_ON_UPLOAD=true

# Embedding 批大小（DashScope text-embedding-v3 上限为 10）
EMBEDDING_BATCH_SIZE=10

# 大 PDF 页级分批：超过阈值页数时按批解析并推送进度心跳
PDF_BATCH_PAGE_THRESHOLD=50
PDF_PAGE_BATCH_SIZE=25
PDF_MAX_PAGES=2000

# 扫描件 OCR：对无文字层 PDF 页调用视觉模型识别（DashScope qwen-vl-ocr）
OCR_ENABLED=true
OCR_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OCR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OCR_MODEL=qwen-vl-ocr-latest
OCR_TIMEOUT_SECONDS=120
PDF_OCR_DPI=200

# GraphRAG 监控阈值：超过/低于时输出 WARN 日志
GRAPHRAG_TIMEOUT_SECONDS=120
GRAPHRAG_SLOW_QUERY_THRESHOLD_MS=500
GRAPHRAG_FRESHNESS_THRESHOLD_DAYS=7
GRAPHRAG_MIN_EXTRACTION_ENTITIES=1

# FastAPI 运行端口（避免与本地其他项目冲突，后台修改后需重启生效）
BACKEND_PORT=8001

# =======================
# 认证配置（JWT）
# =======================
JWT_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# =======================
# 适配器开关
# =======================
# 检索适配器：native | langchain
RETRIEVAL_ADAPTER=native

# 解析器：native | llamaindex（修改后需重建索引生效）
PARSER=native

# 编排模式：native | langchain | agentic
ORCHESTRATION_MODE=native

# Agentic 编排中断点（触发式）：启用后多跳分解后会暂停执行，等待人工确认再继续
AGENTIC_INTERRUPT_ENABLED=false

# LangGraph 编排状态持久化
# 后端：sqlite（单进程本地，默认） | redis（多进程共享，复用 REDIS_URL）
CHECKPOINT_BACKEND=sqlite
CHECKPOINT_SQLITE_PATH=./data/checkpoints.sqlite
# Redis checkpoint key 前缀，避免与现有缓存/锁/Pub-Sub key 冲突
CHECKPOINT_REDIS_PREFIX=cloudbrief:checkpoint
# Redis checkpoint 过期时间（分钟），0 表示不过期
CHECKPOINT_REDIS_TTL=0
