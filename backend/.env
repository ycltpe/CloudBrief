# =======================
# 模型配置（DashScope）
# =======================
LLM_API_KEY=sk-d216c6aa4da54a11a2e5c2342ceb3cd0
EMBEDDING_API_KEY=sk-d216c6aa4da54a11a2e5c2342ceb3cd0
RERANKER_API_KEY=sk-d216c6aa4da54a11a2e5c2342ceb3cd0
OCR_API_KEY=sk-d216c6aa4da54a11a2e5c2342ceb3cd0
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OCR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1

EMBEDDING_MODEL=text-embedding-v2
RERANKER_MODEL=qwen3-rerank
LLM_MODEL=qwen3.6-plus

# 可选：dashscope | local
# local 为权威路径，不回退云端；dashscope 模式下本地端点作为失败降级
LLM_PROVIDER=dashscope
EMBEDDING_PROVIDER=dashscope
RERANKER_PROVIDER=dashscope

# 本地 LLM fallback 配置示例（仅当 LLM_PROVIDER=local 时生效）
# LOCAL_LLM_URL=http://localhost:11434/v1
# LOCAL_LLM_MODEL=qwen3:7b

# 本地 Reranker 配置示例（仅当 RERANKER_PROVIDER=local 时生效）
# LOCAL_RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B

# =======================
# 存储配置
# =======================
MILVUS_URI=http://localhost:19531
MILVUS_COLLECTION=cloudbrief_chunks

REDIS_URL=redis://localhost:6381/0

MYSQL_URL=mysql+pymysql://cloudbrief:cloudbrief@localhost:3307/cloudbrief

BM25_INDEX_PATH=./data/bm25_index.pkl

# Neo4j 图数据库（GraphRAG 可选依赖）
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cloudbrief

# =======================
# 业务配置
# =======================
LOG_LEVEL=INFO

# 拒答阈值：reranker 最高分低于该值时直接拒答（评测阶段根据 Eval Set 调优）
REFUSAL_THRESHOLD=0.3

# 时效阈值（天）：来源更新时间与当前时间差超过该值时提示过期
STALE_THRESHOLD_DAYS=90

# 多轮历史保留轮数
MAX_HISTORY_ROUNDS=10

# 模型调用超时（秒）
REQUEST_TIMEOUT=30

# Embedding 批大小（DashScope text-embedding-v3 上限为 10）
EMBEDDING_BATCH_SIZE=10

# FastAPI 运行端口（避免与本地其他项目冲突）
BACKEND_PORT=8001

# =======================
# 认证配置（JWT）
# =======================
JWT_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# =======================
# 适配器开关
# =======================
# 检索适配器：native | langchain
RETRIEVAL_ADAPTER=native

# 解析器：native | llamaindex
PARSER=native
